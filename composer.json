{
  "name": "semitexa/blockchain",
  "description": "Semitexa Blockchain - immutable verification log for ORM operations and audit trails",
  "type": "semitexa-module",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "semitexa/core": "*",
    "semitexa/orm": "*",
    "basis-company/nats": "^1.1",
    "ext-sqlite3": "*",
    "ext-openssl": "*"
  },
  "autoload": {
    "psr-4": {
      "Semitexa\\Blockchain\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Semitexa\\Blockchain\\Tests\\": "tests/"
    }
  },
  "extra": {
    "semitexa-module": {
      "extends": null
    }
  },
  "keywords": [
    "semitexa",
    "blockchain",
    "audit-log",
    "integrity",
    "verification",
    "orm"
  ]
}
