{
    "name": "semitexa/blockchain",
    "description": "Semitexa Blockchain - immutable verification log for ORM operations and audit trails",
    "version": "v1.0.5",
    "type": "semitexa-module",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "semitexa/core": "^1.0",
        "semitexa/orm": "^1.0",
        "php-amqplib/php-amqplib": "^3.0",
        "ext-sqlite3": "*",
        "ext-openssl": "*"
    },
    "autoload": {
        "psr-4": {
            "Semitexa\\Blockchain\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Semitexa\\Blockchain\\Tests\\": "tests/"
        }
    },
    "extra": {
        "semitexa-module": {
            "extends": null
        }
    },
    "keywords": [
        "semitexa",
        "blockchain",
        "audit-log",
        "integrity",
        "verification",
        "orm"
    ]
}
